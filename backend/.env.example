# =============================================================================
# Backend Environment Variables — Source of Truth
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to source control.
#
# Storage convention per variable:
#   [SECRET]  → GCP Secret Manager (prod/staging) + .env (local)
#   [CONFIG]  → Cloud Run --set-env-vars (prod/staging) + .env (local) — not sensitive
#   [RUNTIME] → set directly in code or docker-compose — no GCP Secret Manager needed
#
# GitHub Actions secrets needed (CI/CD only — not in this file):
#   WIF_PROVIDER, WIF_SERVICE_ACCOUNT   — GCP OIDC auth (replaces JSON key)
#   DATABASE_URL_STAGING                — prisma migrate deploy on staging
#   DATABASE_URL_PROD                   — prisma migrate deploy on prod
#   JWT_ACCESS_SECRET, JWT_REFRESH_SECRET — integration tests sign real tokens

# -----------------------------------------------------------------------------
# Database                                                             [SECRET]
# -----------------------------------------------------------------------------
# Local dev: Docker PostgreSQL (see docker-compose.yml)
# Staging/Prod: Neon.tech — always include connection pool params
# Generate Neon URL: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://doc_classifier:doc_classifier@localhost:5432/doc_classifier?connection_limit=2&pool_timeout=10

# -----------------------------------------------------------------------------
# Application                                                          [RUNTIME]
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# JWT Authentication                                                   [SECRET]
# Must be at least 64 random hex characters (512 bits).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Access token TTL: 15 min (hardcoded — NFR07)
# Refresh token TTL: 7 days (hardcoded — NFR07)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM at-rest)                                    [SECRET]
# Must be exactly 32 random bytes encoded as hex (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by: EncryptionService (shared/infrastructure/encryption/)
# -----------------------------------------------------------------------------
AES_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Storage                                                 [CONFIG]
# Not sensitive — passed via --set-env-vars in gcloud run deploy.
# Bucket must have uniform access control, no public access (NFR09).
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=doc-classifier-app-documents
GCS_PROJECT_ID=

# -----------------------------------------------------------------------------
# AI — Gemini (Google AI Studio)                                       [SECRET]
# https://aistudio.google.com/app/apikey
# Free tier: 15 RPM / 1M tokens/day for Gemini 2.0 Flash
# Used only in infrastructure/ai/ — never imported in domain/ or application/
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server Authentication                                            [SECRET]
# Static API key validated by McpApiKeyGuard via X-MCP-Key header.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# -----------------------------------------------------------------------------
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Observability — Sentry                                               [SECRET]
# https://sentry.io → Project → Settings → Client Keys (DSN)
# DSN contains an embedded token — treat as secret.
# GDPR: beforeSend filter active (no PII in events — see instrument.ts)
# Not needed in GitHub Actions (CI errors should not go to Sentry).
# -----------------------------------------------------------------------------
SENTRY_DSN=


# -----------------------------------------------------------------------------
# Observability — OpenTelemetry & Grafana Cloud                        [SECRET]
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT: OTLP HTTP endpoint for traces/metrics/logs (Grafana Cloud)
# GRAFANA_API_KEY: API key (Access Policy: write.metrics, write.traces, write.logs)
# GRAFANA_INSTANCE_ID: (optionnel) ID de stack Grafana, requis par certains agents
# OTEL_SERVICE_NAME: nom logique du service (ex: nestjs-backend)
# OTEL_RESOURCE_ATTRIBUTES: attributs additionnels (namespace, version, etc.)
#
# Recommended usage (2026):
#  - Generate a dedicated Access Policy (explicit scopes)
#  - Generate an API key associated with this policy
#  - Store these variables in GCP Secret Manager (prod) and .env (local)
#  - Configure the OpenTelemetry exporter to point to the Grafana Cloud OTLP endpoint
#
# Exemples:
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-gb-south-1.grafana.net/otlp
GRAFANA_API_KEY=
GRAFANA_INSTANCE_ID=
OTEL_SERVICE_NAME=doc-classifier-app-backend
OTEL_RESOURCE_ATTRIBUTES=service.namespace=production,service.version=1.0.0,deployment.environment=production
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# -----------------------------------------------------------------------------
# Rate Limiting                                                        [CONFIG]
# Configurable without redeploy (NFR10).
# THROTTLE_TTL: time window in seconds (default: 60)
# THROTTLE_LIMIT: max requests per TTL window per IP (default: 100)
# Auth endpoints have stricter limits defined in code.
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# Feature flags / tunables                                             [CONFIG]
# Configurable without redeploy — passed via --set-env-vars in Cloud Run.
# Code defaults are applied if variable is absent (safe for local dev).
# -----------------------------------------------------------------------------
# Minimum AI confidence score to auto-validate classification (NFR01c, default: 0.7)
CONFIDENCE_THRESHOLD=0.7

# Maximum upload file size in MB — HTTP 413 returned if exceeded (NFR01b, default: 10)
FILE_SIZE_LIMIT_MB=10
