# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# All secrets must be stored in GCP Secret Manager (prod) or .env (local dev).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local dev: points to Docker PostgreSQL (see docker-compose.yml)
# Staging/Prod: Neon.tech connection string
DATABASE_URL=postgresql://doc_classifier:doc_classifier@localhost:5432/doc_classifier?connection_limit=2&pool_timeout=10

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# JWT Authentication
# Secret must be at least 64 random hex characters.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM at-rest)
# Must be exactly 32 random bytes encoded as hex (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
AES_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Storage
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=doc-classifier-app-documents
GCS_PROJECT_ID=

# -----------------------------------------------------------------------------
# AI — Gemini (Google AI Studio)
# https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server Authentication
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# -----------------------------------------------------------------------------
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTLP_ENDPOINT=

# Grafana Cloud — Prometheus remote write
GRAFANA_REMOTE_WRITE_URL=
GRAFANA_API_KEY=

# -----------------------------------------------------------------------------
# Feature flags / tunables (configurable without redeploy)
# -----------------------------------------------------------------------------
# Minimum AI confidence score to mark a document as DONE (default: 0.7)
CONFIDENCE_THRESHOLD=0.7

# Maximum upload file size in MB (default: 10)
FILE_SIZE_LIMIT_MB=10
