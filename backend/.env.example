# =============================================================================
# Backend Environment Variables — Complete Reference
# =============================================================================
# This file is the single source of truth for every key used by the backend.
# Copy to .env for local development. NEVER commit .env to source control.
#
# Storage tag per variable (indicates where the value must be stored in prod):
#   [SECRET]     → GCP Secret Manager + .env locally
#                  Injected into Cloud Run at runtime via --set-secrets
#   [CONFIG]     → Cloud Run --set-env-vars + .env locally (not sensitive)
#                  See deploy.yml env_vars block
#   [RUNTIME]    → Hardcoded in docker-compose / code defaults — not in GCP
#   [GH_SECRET]  → GitHub Actions secret only (not in this file, not in GCP)
#                  Settings → Secrets and variables → Actions → Secrets
#   [GH_VAR]     → GitHub Actions variable — non-sensitive (vars.* in workflows)
#                  Settings → Secrets and variables → Actions → Variables
#
# Full setup guide with CLI commands: docs/ci-cd-secrets.md
#
# =============================================================================
# CI/CD-only keys — not present as variables below (no local value needed)
# =============================================================================
#
# [GH_SECRET]  WIF_PROVIDER          — GCP OIDC provider resource name
# [GH_SECRET]  WIF_SERVICE_ACCOUNT   — SA email for OIDC impersonation
# [GH_SECRET]  DATABASE_URL_PROD     — Neon prod URL (prisma migrate deploy)
# [GH_SECRET]  JWT_ACCESS_SECRET     — same value as below (CI integration tests)
# [GH_SECRET]  JWT_REFRESH_SECRET    — same value as below (CI integration tests)
# [GH_SECRET]  FIREBASE_SERVICE_ACCOUNT — Firebase SA JSON (frontend deploy)
#
# [GH_VAR]     GCP_PROJECT_ID        — GCP project ID (Artifact Registry + Cloud Run)
# [GH_VAR]     GCP_REGION            — GCP region (e.g. europe-west1)
# [GH_VAR]     CLOUD_RUN_SERVICE     — Cloud Run service name
# [GH_VAR]     GCS_BUCKET_NAME       — same value as below
# [GH_VAR]     FIREBASE_PROJECT_ID   — Firebase project ID

# -----------------------------------------------------------------------------
# Database                                                             [SECRET]
# -----------------------------------------------------------------------------
# Local dev: Docker PostgreSQL (see docker-compose.yml)
# Staging/Prod: Neon.tech — use the direct (non-pooled) connection string.
# Generate Neon URL: https://console.neon.tech → Connection Details
# Note: Do NOT include ?connection_limit or ?pool_timeout here — those were
# Prisma 6-specific params. Pool settings are now configured in PrismaService
# via pg.Pool constructor (max: 2, connectionTimeoutMillis: 10_000).
DATABASE_URL=postgresql://doc_classifier:doc_classifier@localhost:5432/doc_classifier

# -----------------------------------------------------------------------------
# Application                                                          [RUNTIME]
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# JWT Authentication                                                   [SECRET]
# Must be at least 64 random hex characters (512 bits).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Access token TTL: 15 min (hardcoded — NFR07)
# Refresh token TTL: 7 days (hardcoded — NFR07)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM at-rest)                                    [SECRET]
# Must be exactly 32 random bytes encoded as hex (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by: EncryptionService (shared/infrastructure/encryption/)
# -----------------------------------------------------------------------------
AES_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Storage                                                 [CONFIG]
# Not sensitive — passed via --set-env-vars in gcloud run deploy.
# Bucket must have uniform access control, no public access (NFR09).
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=doc-classifier-app-documents
GCS_PROJECT_ID=

# -----------------------------------------------------------------------------
# AI — Gemini (Google AI Studio)                                       [SECRET]
# https://aistudio.google.com/app/apikey
# Free tier: 15 RPM / 1M tokens/day for Gemini 2.0 Flash
# Used only in infrastructure/ai/ — never imported in domain/ or application/
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server Authentication                                            [SECRET]
# Static API key validated by McpApiKeyGuard via X-MCP-Key header.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# -----------------------------------------------------------------------------
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Observability — Sentry                                               [SECRET]
# https://sentry.io → Project → Settings → Client Keys (DSN)
# DSN contains an embedded token — treat as secret.
# GDPR: beforeSend filter active (no PII in events — see instrument.ts)
# Not needed in GitHub Actions (CI errors should not go to Sentry).
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry & Grafana Cloud (credentials)          [SECRET]
# -----------------------------------------------------------------------------
# GRAFANA_INSTANCE_ID + GRAFANA_API_KEY are combined by instrument.ts into
# an Authorization: Basic header for OTLP authentication — never logged.
# Access Policy scopes required: metrics:write, traces:write, logs:write
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-gb-south-1.grafana.net/otlp
GRAFANA_INSTANCE_ID=
GRAFANA_API_KEY=

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry & Grafana Cloud (exporters)            [CONFIG]
# -----------------------------------------------------------------------------
# Non-sensitive OTEL configuration — passed via --set-env-vars in Cloud Run.
OTEL_SERVICE_NAME=doc-classifier-app-backend
OTEL_RESOURCE_ATTRIBUTES=service.namespace=production,service.version=1.0.0,deployment.environment=production
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# -----------------------------------------------------------------------------
# Rate Limiting                                                        [CONFIG]
# Configurable without redeploy (NFR10).
# THROTTLE_TTL: time window in seconds (default: 60)
# THROTTLE_LIMIT: max requests per TTL window per IP (default: 100)
# Auth endpoints have stricter limits defined in code.
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# Feature flags / tunables                                             [CONFIG]
# Configurable without redeploy — passed via --set-env-vars in Cloud Run.
# Code defaults are applied if variable is absent (safe for local dev).
# -----------------------------------------------------------------------------
# Minimum AI confidence score to auto-validate classification (NFR01c, default: 0.7)
CONFIDENCE_THRESHOLD=0.7

# Maximum upload file size in MB — HTTP 413 returned if exceeded (NFR01b, default: 10)
FILE_SIZE_LIMIT_MB=10
