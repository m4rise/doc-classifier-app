// Prisma schema — doc-classifier-app
// Docs: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference
// Conventions: UUID PK, @@map (snake_case tables), nullable-first (RF-14),
//              Prisma enums for finite domain values, migrations additive-only.

generator client {
  provider = "prisma-client-js"
  // Prisma 7: output is required — client no longer generated in node_modules.
  // Path is relative to this schema file (prisma/).
  // Import path in app code: '../../../generated/prisma' from shared/infrastructure/database/
  // See: https://www.prisma.io/docs/guides/upgrade-prisma-orm/v7#schema-changes
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: url is no longer supported here — moved to prisma.config.ts (ADR-DATA-002).
  // Pool configuration (RF-02) is in PrismaService via pg.Pool constructor.
  // See: https://www.prisma.io/docs/guides/upgrade-prisma-orm/v7#prisma-config
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// Role is a first-class domain value — enum prevents arbitrary strings in DB.
// New roles (e.g. MODERATOR) require a Prisma migration: additive, not breaking.
enum Role {
  USER
  ADMIN
}

enum DocumentStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// ---------------------------------------------------------------------------
// User — Epic 1 / Story 1.3 (bootstrap)
// Relations (documents, refreshTokens, consents) added in Epic 2 & 3.
// ---------------------------------------------------------------------------
model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  role           Role            @default(USER)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  refreshTokens  RefreshToken[]
  consentRecords ConsentRecord[]
  documents      Document[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  jti       String    @unique
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("refresh_tokens")
}

model ConsentRecord {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tosVersion String
  acceptedAt DateTime
  ipAddress  String?

  @@map("consent_records")
}

model Document {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName     String
  mimeType         String
  sizeBytes        Int
  storageKey       String            @unique @default(uuid())
  status           DocumentStatus    @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  processingResult ProcessingResult?

  @@unique([userId, createdAt, id])
  @@index([userId])
  @@map("documents")
}

model ProcessingResult {
  id              String   @id @default(uuid())
  documentId      String   @unique
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedText   String?
  classification  String?
  summary         String?
  confidenceScore Float?
  language        String?
  needsReview     Boolean  @default(false)
  errorMessage    String?
  processedAt     DateTime @default(now())

  @@map("processing_results")
}
